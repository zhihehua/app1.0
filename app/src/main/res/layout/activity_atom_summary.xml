<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <!-- 顶部标题 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1E1E1E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/btn_back"
            android:scaleType="centerInside"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="智能复盘总结"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 场景/标签选择区域 (复刻 PDF 页面) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:padding="15dp"
        android:layout_margin="10dp"
        android:elevation="4dp">

        <Spinner
            android:id="@+id/spinner_main_category"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_spinner" />

        <Spinner
            android:id="@+id/spinner_second_category"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:background="@drawable/bg_spinner" />
    </LinearLayout>

    <!-- 总结内容展示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="15dp"
        app:cardElevation="2dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="15dp"
            android:fadeScrollbars="true">

            <TextView
                android:id="@+id/tv_ai_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请先选择上方场景与标签，然后点击下方开启智能灵魂复盘。"
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- 底部触发按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_start_summary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_dark_gradient"
            android:text="开启智能复盘"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
