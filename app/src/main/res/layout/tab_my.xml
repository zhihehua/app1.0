<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_tab_my"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#f5f5f5">

    <!-- 头像头部 - 增强立体感 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_card"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        android:translationZ="4dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_user_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="#FFFFFF"
            android:padding="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/user"
            app:shapeAppearanceOverlay="@style/CircleAppearanceOverlay"
            app:strokeColor="#EEEEEE"
            app:strokeWidth="2dp" />

        <!-- 用户名和ID容器 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_username_real"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="纸盒花"
                android:textColor="#333333"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="id: 20260418"
                android:textColor="#999999"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 右侧切换/修改按钮 -->
        <ImageView
            android:id="@+id/btn_change_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/change"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#555555" />
    </LinearLayout>

    <!-- 卡片提示词 -->
    <TextView
        android:id="@+id/tv_card_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="28dp"
        android:text="您可能在找："
        android:textColor="#888888"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 炫彩垂直叠层卡片容器：紧挨着上方文字并占据余下空间 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_cards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>
