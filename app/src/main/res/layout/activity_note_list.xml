<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_325">

    <!-- 标题栏容器 -->
    <RelativeLayout
        android:id="@+id/toolbar_note_list"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/transparent"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/btn_back"
            app:tint="#1A2634" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="我的智记"
            android:textColor="#1A2634"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 1. 顶部内容容器：包含搜索栏和提示 -->
    <LinearLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="@null"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/toolbar_note_list">

        <!-- 悬浮椭圆搜索栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/search_bg_floating"
            android:elevation="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">


            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="按照: 内容/标签/分类 搜索..."
                android:paddingStart="12dp"
                android:textColor="#1A2634"
                android:textColorHint="#991A2634"
                android:textSize="15sp"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/btn_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/look_around"
                app:tint="#1A2634"
                android:padding="10dp"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <!-- 晃动提示 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#CCFFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="所有的二级标签都在下面啦,晃动下手机试试~"
            android:textColor="@color/black_400"
            android:textSize="12sp"
            android:elevation="4dp" />

    </LinearLayout>

    <!-- 2. 容器感边框层：放置在 WebView 之下，由于 WebView 透明，它会透出来 -->
    <View
        android:id="@+id/view_container_border"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_open_container"
        app:layout_constraintTop_toBottomOf="@id/top_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 3. WebView 放在容器内，彻底透明 -->
    <WebView
        android:id="@+id/webview_tags"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="18dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
