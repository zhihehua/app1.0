<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底部阴影/厚度层：使用深蓝色调，营造立体深度 -->
    <item
        android:bottom="1dp"
        android:left="2dp"
        android:right="2dp"
        android:top="4dp">
        <shape>
            <solid android:color="#1A000000" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- 主体背景层：颜色调淡为更清爽的蓝灰色 (#34495E) -->
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape>
            <solid android:color="#34495E" />
            <corners android:radius="30dp" />
            <stroke
                android:width="1dp"
                android:color="#465C71" />
        </shape>
    </item>
</layer-list>