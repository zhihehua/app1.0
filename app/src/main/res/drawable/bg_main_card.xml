<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. 深度阴影：模拟容器向内凹陷的轻微阴影 -->
    <item>
        <shape>
            <solid android:color="#15000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- 2. 主体毛玻璃层：减轻了灰色度，使其更加通透 -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="3dp">
        <shape>
            <!-- 调淡了灰色，透明度调整为更清澈的比例 -->
            <solid android:color="#80E8E8E8" />
            <corners android:radius="24dp" />
            <!-- 高亮边缘：强化玻璃质感 -->
            <stroke
                android:width="1dp"
                android:color="#BFFFFFFF" />
        </shape>
    </item>

    <!-- 3. 轻微的内发光/阴影：维持立体感但减少厚重感 -->
    <item
        android:bottom="8dp"
        android:left="3dp"
        android:right="3dp"
        android:top="2dp">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="#1A000000" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>