<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape>
            <solid android:color="#1A000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- 主体背景层 -->
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape>
            <solid android:color="#FFFFFF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#EEEEEE" />
        </shape>
    </item>
</layer-list>